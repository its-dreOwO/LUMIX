{
  "expo": {
    "name": "LUMIX",
    "slug": "lumix",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lumix",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icons/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "icon": "./assets/icons/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.lumix.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "plugins": [
      "./plugins/withGradleProperties",
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LUMIX uses your location to show local weather."
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/icon.png",
          "color": "#000000",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "LUMIX needs calendar access to create and read events."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7bccb164-6277-42f5-a651-c6b857a8de29"
      }
    },
    "owner": "dre2"
  }
}
