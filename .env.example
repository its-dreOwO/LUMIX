# No API keys required for v1 — all data is on-device or uses keyless public APIs.
# Copy to .env and fill in if you add integrations later.

# Future: Google Calendar OAuth
# GOOGLE_CLIENT_ID=

# Future: Cloud sync backend
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Dev override: force MockProvider even on device (set to "true" to bypass Gemma load)
# EXPO_PUBLIC_USE_MOCK_LLM=false
